<script>
(function() {
  /* ── Predictive Search ── */
  var openBtn  = document.getElementById('search-open');
  var closeBtn = document.getElementById('search-close');
  var drawer   = document.getElementById('search-drawer');
  var overlay  = document.getElementById('search-overlay');
  var input    = document.getElementById('search-input');
  var form     = document.getElementById('search-form');
  var panel    = document.getElementById('search-pred-panel');
  var grid     = document.getElementById('search-pred-results');
  var footer   = document.getElementById('search-pred-footer');
  var countEl  = document.getElementById('search-pred-count');
  var allLink  = document.getElementById('search-pred-all');
  var emptyEl  = document.getElementById('search-pred-empty');

  var debTimer, activeIdx = -1;

  function openSearch() {
    drawer.classList.add('is-open');
    overlay.classList.add('is-open');
    drawer.setAttribute('aria-hidden', 'false');
    overlay.setAttribute('aria-hidden', 'false');
    openBtn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    if (window.__lenis) window.__lenis.stop();
    setTimeout(function() { if (input) input.focus(); }, 80);
  }

  function closeSearch() {
    drawer.classList.remove('is-open');
    overlay.classList.remove('is-open');
    drawer.setAttribute('aria-hidden', 'true');
    overlay.setAttribute('aria-hidden', 'true');
    openBtn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    if (window.__lenis) window.__lenis.start();
    openBtn.focus();
    clearResults();
  }

  function clearResults() {
    panel.classList.remove('has-results');
    while (grid.firstChild) grid.removeChild(grid.firstChild);
    footer.style.display = 'none';
    emptyEl.style.display = 'none';
    activeIdx = -1;
  }

  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(cents % 100 === 0 ? 0 : 2);
  }

  function renderResults(products, query) {
    clearResults();
    if (!products.length) {
      panel.classList.add('has-results');
      emptyEl.style.display = '';
      return;
    }

    panel.classList.add('has-results');
    products.forEach(function(p, i) {
      var a    = document.createElement('a');
      a.className   = 'search-pred-item';
      a.href        = p.url;
      a.tabIndex    = 0;
      a.style.cssText = 'opacity:0;transform:translateY(18px);transition:opacity 0.35s ease ' + (i*0.07) + 's,transform 0.42s cubic-bezier(0.16,1,0.3,1) ' + (i*0.07) + 's,border-color 0.2s';

      var imgDiv = document.createElement('div');
      imgDiv.className = 'search-pred-img';
      if (p.featured_image && p.featured_image.url) {
        var img = document.createElement('img');
        img.src       = p.featured_image.url.replace(/(\.\w+)(\?|$)/, '_400x$1$2');
        img.alt       = p.title;
        img.loading   = 'lazy';
        img.decoding  = 'async';
        imgDiv.appendChild(img);
      }
      a.appendChild(imgDiv);

      var body  = document.createElement('div');
      body.className = 'search-pred-body';
      var name  = document.createElement('div');
      name.className  = 'search-pred-name';
      name.textContent = p.title;
      body.appendChild(name);

      if (p.price) {
        var price = document.createElement('div');
        price.className  = 'search-pred-price';
        price.textContent = formatMoney(p.price);
        body.appendChild(price);
      }
      a.appendChild(body);
      grid.appendChild(a);

      requestAnimationFrame(function() {
        setTimeout(function() {
          a.style.opacity   = '1';
          a.style.transform = 'translateY(0)';
        }, 20 + i * 60);
      });
    });

    countEl.textContent = products.length + ' result' + (products.length === 1 ? '' : 's') + ' for "' + query + '"';
    allLink.href        = '/search?type=product&q=' + encodeURIComponent(query);
    footer.style.display = '';
  }

  function fetchPredictive(query) {
    if (!query || query.length < 2) { clearResults(); return; }
    if (form) form.classList.add('is-loading');
    fetch('/search/suggest.json?q=' + encodeURIComponent(query) + '&resources[type]=product&resources[limit]=4&resources[options][unavailable_products]=last')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (form) form.classList.remove('is-loading');
        var products = (data.resources && data.resources.results && data.resources.results.products) || [];
        renderResults(products, query);
      })
      .catch(function() { if (form) form.classList.remove('is-loading'); });
  }

  function getItems() { return Array.from(grid.querySelectorAll('.search-pred-item')); }
  function setActive(idx) {
    var items = getItems();
    items.forEach(function(el) { el.classList.remove('is-active'); });
    if (idx >= 0 && idx < items.length) {
      items[idx].classList.add('is-active');
      items[idx].focus();
      activeIdx = idx;
    } else {
      activeIdx = -1;
      if (input) input.focus();
    }
  }

  if (input) {
    input.addEventListener('input', function() {
      clearTimeout(debTimer);
      debTimer = setTimeout(function() { fetchPredictive(input.value.trim()); }, 220);
    });
    input.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowDown' && getItems().length) { e.preventDefault(); setActive(0); }
      if (e.key === 'Escape') closeSearch();
    });
  }

  if (drawer) {
    drawer.addEventListener('keydown', function(e) {
      var items = getItems();
      if (!items.length) return;
      if (e.key === 'ArrowDown') { e.preventDefault(); setActive(Math.min(activeIdx + 1, items.length - 1)); }
      if (e.key === 'ArrowUp')   { e.preventDefault(); setActive(activeIdx <= 0 ? -1 : activeIdx - 1); }
      if (e.key === 'Escape')    closeSearch();
    });
  }

  if (openBtn) openBtn.addEventListener('click', openSearch);
  if (closeBtn) closeBtn.addEventListener('click', closeSearch);
  if (overlay)  overlay.addEventListener('click', closeSearch);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && drawer && drawer.classList.contains('is-open')) closeSearch();
  });

  {%- comment -%}
    Nav scroll handler:
    - Homepage/collection: simple scrollY > 60 triggers visual treatment only
    - Product page: product-main.liquid owns the scroll handler (hero-based trigger + product info)
    This prevents two handlers fighting over the same class.
  {%- endcomment -%}
  {%- unless template.name == 'product' -%}
    var navCard = document.getElementById('navCard');
    if (navCard) {
      window.addEventListener('scroll', function() {
        navCard.classList.toggle('nav-scrolled', window.scrollY > 60);
      }, { passive: true });
    }
  {%- endunless -%}

  /* ── Mobile menu ── */
  var mobOpenBtn  = document.getElementById('mobMenuOpen');
  var mobCloseBtn = document.getElementById('mobMenuClose');
  var mobMenu     = document.getElementById('mobMenu');
  var mobOverlay  = document.getElementById('mobOverlay');

  function openMobMenu() {
    if (!mobMenu) return;
    var links = mobMenu.querySelectorAll('.mob-menu__nav a');
    // Reset link positions before animating
    links.forEach(function(link) {
      link.style.opacity = '0';
      link.style.transform = 'translateY(18px)';
      link.style.transition = 'none';
    });
    mobMenu.classList.add('is-open');
    mobOverlay.classList.add('is-open');
    if (mobOpenBtn) { mobOpenBtn.classList.add('is-open'); mobOpenBtn.setAttribute('aria-expanded', 'true'); }
    mobMenu.setAttribute('aria-hidden', 'false');
    mobOverlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    if (window.__lenis) window.__lenis.stop();
    // Stagger links in
    links.forEach(function(link, i) {
      setTimeout(function() {
        link.style.transition = 'opacity 0.45s cubic-bezier(0.16,1,0.3,1), transform 0.45s cubic-bezier(0.16,1,0.3,1), color 0.25s ease';
        link.style.opacity = '1';
        link.style.transform = 'translateY(0)';
      }, 80 + i * 55);
    });
  }

  function closeMobMenu() {
    if (!mobMenu) return;
    mobMenu.classList.remove('is-open');
    mobOverlay.classList.remove('is-open');
    if (mobOpenBtn) { mobOpenBtn.classList.remove('is-open'); mobOpenBtn.setAttribute('aria-expanded', 'false'); }
    mobMenu.setAttribute('aria-hidden', 'true');
    mobOverlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (window.__lenis) window.__lenis.start();
  }

  if (mobOpenBtn) mobOpenBtn.addEventListener('click', openMobMenu);
  if (mobCloseBtn) mobCloseBtn.addEventListener('click', closeMobMenu);
  if (mobOverlay) mobOverlay.addEventListener('click', closeMobMenu);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && mobMenu && mobMenu.classList.contains('is-open')) closeMobMenu();
  });
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "link_list", "id": "menu", "label": "Main menu", "default": "main-menu" }
  ]
}
{% endschema %}
