{%- style -%}
  .nav-card {
    background: var(--card-bg);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
    height: 58px;
    position: sticky;
    top: 28px;
    z-index: 200;
    overflow: hidden;
    transition: height 0.4s cubic-bezier(0.16,1,0.3,1), box-shadow 0.4s ease, background 0.4s ease;
  }
  .nav-card.nav-scrolled {
    background: rgba(26,20,10,0.96);
    box-shadow: 0 8px 36px rgba(0,0,0,0.55), 0 1px 0 rgba(196,168,122,0.12);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  }
  .nav-card.nav-scrolled::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0;
    height: 1px; background: rgba(196,168,122,0.18);
  }
  .nav-left  { display: flex; align-items: center; gap: 36px; }
  .nav-logo {
    font-family: var(--font-display); font-size: 11px; font-weight: 600;
    letter-spacing: 0.20em; text-transform: uppercase;
    color: var(--cream); white-space: nowrap; flex-shrink: 0;
  }
  .nav-logo a { color: inherit; text-decoration: none; }

  /* Back link — PDP only */
  .nav-back {
    font-family: var(--font-display);
    font-size: 10px; font-weight: 600;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--cream); white-space: nowrap;
    display: flex; align-items: center; gap: 6px;
    transition: color 0.3s, transform 0.3s;
    text-decoration: none; flex-shrink: 0;
  }
  .nav-back:hover { color: var(--white); transform: translateX(-3px); }

  .nav-links { display: flex; gap: 24px; list-style: none; }
  .nav-links a {
    font-size: 10px; font-weight: 600; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--muted);
    transition: color 0.3s; position: relative;
  }
  .nav-links a::after {
    content: ''; position: absolute; bottom: -4px; left: 0;
    width: 0; height: 1px; background: var(--cream);
    transition: width 0.3s cubic-bezier(0.16,1,0.3,1);
  }
  .nav-links a:hover { color: var(--cream); }
  .nav-links a:hover::after { width: 100%; }
  .nav-right { display: flex; align-items: center; gap: 20px; }
  .nav-icon {
    width: 18px; height: 18px; cursor: pointer;
    opacity: 0.45; transition: opacity 0.3s, transform 0.2s;
    color: var(--cream);
  }
  .nav-icon:hover { opacity: 1; transform: scale(1.1); }
  .cart-count {
    font-size: 10px; font-weight: 700; background: var(--earth);
    color: var(--card-bg); border-radius: 50%; width: 16px; height: 16px;
    display: flex; align-items: center; justify-content: center;
    position: absolute; top: -6px; right: -8px;
  }
  .nav-cart-wrap { position: relative; display: flex; }
  .nav-search-btn {
    background: none; border: none; padding: 0;
    display: flex; align-items: center;
  }
  .nav-wishlist-btn {
    background: none; border: none; padding: 0;
    display: flex; align-items: center;
  }

  /* Mobile nav adjustments */
  @media (max-width: 900px) {
    .nav-card { top: 14px; padding: 0 24px; }
    .nav-links { display: none; }
    .nav-card.nav-scrolled .nav-right .nav-search-btn,
    .nav-card.nav-scrolled .nav-right .nav-wishlist-btn { display: none; }
  }
  @media (max-width: 560px) {
    .nav-card { top: 10px; height: 50px; padding: 0 20px; border-radius: 12px; }
  }

  /* ── Hamburger button (mobile only, inside nav) ── */
  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 36px; height: 36px;
    background: none; border: none; cursor: pointer;
    padding: 0; flex-shrink: 0;
  }
  @media (max-width: 900px) { .nav-burger { display: flex; } }
  .nav-burger__line {
    display: block;
    width: 18px; height: 1.5px;
    background: var(--cream);
    opacity: 0.65;
    transform-origin: center;
    transition: transform 0.35s cubic-bezier(0.16,1,0.3,1), opacity 0.2s ease, width 0.3s cubic-bezier(0.16,1,0.3,1);
  }
  .nav-burger.is-open .nav-burger__line:nth-child(1) { transform: translateY(6.5px) rotate(45deg); opacity: 0.9; }
  .nav-burger.is-open .nav-burger__line:nth-child(2) { opacity: 0; width: 0; }
  .nav-burger.is-open .nav-burger__line:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); opacity: 0.9; }

  /* ── Mobile menu overlay ── */
  .mob-overlay {
    position: fixed; inset: 0; z-index: 250;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
    opacity: 0; pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .mob-overlay.is-open { opacity: 1; pointer-events: all; }

  /* ── Mobile menu panel ── */
  .mob-menu {
    position: fixed; top: 0; left: 0; bottom: 0;
    width: 88vw; max-width: 360px;
    z-index: 251;
    background: var(--card-bg);
    border-right: 1px solid rgba(255,255,255,0.06);
    display: flex; flex-direction: column;
    transform: translateX(-100%);
    transition: transform 0.42s cubic-bezier(0.16,1,0.3,1);
    overflow: hidden;
  }
  .mob-menu.is-open { transform: translateX(0); }
  .mob-menu__header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 22px 24px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    flex-shrink: 0;
  }
  .mob-menu__wordmark {
    font-family: var(--font-display);
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--cream);
  }
  .mob-menu__close {
    background: none; border: none; cursor: pointer;
    color: var(--muted); padding: 4px;
    display: flex; align-items: center;
    transition: color 0.2s;
  }
  .mob-menu__close:hover { color: var(--cream); }
  .mob-menu__close svg { width: 20px; height: 20px; }
  .mob-menu__nav {
    flex: 1; overflow-y: auto;
    padding: 32px 28px;
  }
  .mob-menu__nav ul { list-style: none; display: flex; flex-direction: column; gap: 0; }
  .mob-menu__nav a {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 7vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: rgba(255,249,239,0.4);
    text-decoration: none;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transition: color 0.25s ease;
  }
  .mob-menu__nav a:hover { color: var(--cream); }
  .mob-menu__nav li:last-child a { border-bottom: none; }
  .mob-menu__footer {
    padding: 20px 28px 32px;
    border-top: 1px solid rgba(255,255,255,0.05);
    flex-shrink: 0;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
  }

  /* ── Wishlist badge ── */
  .wishlist-count {
    font-size: 10px; font-weight: 700; background: var(--earth);
    color: var(--card-bg); border-radius: 50%; width: 16px; height: 16px;
    display: flex; align-items: center; justify-content: center;
    position: absolute; top: -6px; right: -8px;
  }
  .nav-wishlist-btn { position: relative; }

  /* ── Toast Notifications ── */
  .aiw-toast-container {
    position: fixed; bottom: 28px; left: 50%;
    transform: translateX(-50%);
    z-index: 500;
    display: flex; flex-direction: column-reverse;
    gap: 8px; pointer-events: none;
  }
  .aiw-toast {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 20px;
    display: flex; align-items: center; gap: 10px;
    font-size: 13px; font-weight: 600; letter-spacing: 0.04em;
    color: var(--cream);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    opacity: 0; transform: translateY(12px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: auto;
    white-space: nowrap;
  }
  .aiw-toast--show { opacity: 1; transform: translateY(0); }
  .aiw-toast__icon { font-size: 14px; }
  .aiw-toast--success .aiw-toast__icon { color: var(--earth); }
  .aiw-toast--error .aiw-toast__icon { color: #e55; }
  .aiw-toast--wishlist .aiw-toast__icon { color: #e88; }

  /* ── Drawer (shared cart + wishlist) ── */
  .drawer-overlay {
    position: fixed; inset: 0; z-index: 400;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(4px);
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .drawer-overlay.is-open { opacity: 1; pointer-events: all; }

  .drawer-panel {
    position: fixed; top: 0; right: 0; bottom: 0;
    width: 420px; max-width: 92vw;
    z-index: 401;
    background: var(--card-bg);
    border-left: 1px solid var(--border);
    display: flex; flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.16,1,0.3,1);
  }
  .drawer-panel.is-open { transform: translateX(0); }

  .drawer-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .drawer-header__title {
    font-family: var(--font-display);
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cream);
  }
  .drawer-close {
    background: none; border: none; cursor: pointer;
    color: var(--muted); padding: 4px;
    transition: color 0.2s;
    display: flex; align-items: center;
  }
  .drawer-close:hover { color: var(--cream); }
  .drawer-close svg { width: 18px; height: 18px; }

  .drawer-body {
    flex: 1; overflow-y: auto;
    padding: 16px 24px;
    -webkit-overflow-scrolling: touch;
  }

  .drawer-footer {
    padding: 20px 24px;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
  }
  .drawer-subtotal {
    display: flex; justify-content: space-between;
    align-items: center; margin-bottom: 16px;
  }
  .drawer-subtotal__label {
    font-size: 11px; font-weight: 700; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--muted);
  }
  .drawer-subtotal__price {
    font-size: 16px; font-weight: 700; color: var(--cream);
  }

  /* Cart/Wishlist drawer items */
  .cd-item {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    gap: 14px; align-items: start;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .cd-item:last-child { border-bottom: none; }
  .cd-item__img {
    width: 64px; height: 80px;
    border-radius: 6px; overflow: hidden;
    background: var(--card-bg2);
  }
  .cd-item__img img { width: 100%; height: 100%; object-fit: cover; }
  .cd-item__title {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.04em; text-transform: uppercase;
    color: var(--cream); text-decoration: none;
    display: block; margin-bottom: 2px;
  }
  .cd-item__variant {
    font-size: 10px; color: var(--muted); margin-bottom: 8px;
  }
  .cd-item__qty-row {
    display: flex; align-items: center; gap: 0;
    border: 1px solid var(--border); border-radius: 6px;
    width: fit-content;
  }
  .cd-qty-btn {
    background: none; border: none; cursor: pointer;
    color: var(--muted); font-size: 14px;
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    transition: color 0.2s;
  }
  .cd-qty-btn:hover { color: var(--cream); }
  .cd-qty-val {
    font-size: 11px; font-weight: 600; color: var(--cream);
    min-width: 20px; text-align: center;
  }
  .cd-item__right {
    display: flex; flex-direction: column;
    align-items: flex-end; gap: 8px;
  }
  .cd-item__price {
    font-size: 13px; font-weight: 700; color: var(--earth);
  }
  .cd-item__remove {
    background: none; border: none; cursor: pointer;
    color: var(--muted); font-size: 16px;
    transition: color 0.2s; padding: 0;
    line-height: 1;
  }
  .cd-item__remove:hover { color: var(--cream); }

  .drawer-empty {
    text-align: center; padding: 48px 0;
    color: var(--muted); font-size: 13px;
  }
  .drawer-empty a {
    display: inline-block; margin-top: 16px;
    padding: 12px 28px;
    background: var(--earth); color: var(--card-bg);
    border-radius: 8px;
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    transition: background 0.3s;
  }
  .drawer-empty a:hover { background: var(--white); }

  .btn-earth {
    display: block; width: 100%;
    padding: 14px 24px;
    background: var(--earth); color: var(--card-bg);
    border: none; border-radius: 8px;
    font-family: var(--font-display); font-size: 11px;
    font-weight: 700; letter-spacing: 0.20em;
    text-transform: uppercase; cursor: pointer;
    text-align: center; text-decoration: none;
    transition: background 0.3s, transform 0.2s;
  }
  .btn-earth:hover { background: var(--white); transform: translateY(-1px); }

  @media (max-width: 560px) {
    .drawer-panel { width: 100%; max-width: 100%; }
    .aiw-toast-container { bottom: 16px; width: calc(100% - 32px); }
    .aiw-toast { white-space: normal; }
  }

  /* ── Search overlay ── */
  .search-overlay {
    position: fixed; inset: 0; z-index: 300;
    background: rgba(4,2,0,0.72);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    opacity: 0; pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .search-overlay.is-open { opacity: 1; pointer-events: all; }

  /* ── Search drawer ── */
  .search-drawer {
    position: fixed; top: 0; left: 0; right: 0; z-index: 301;
    background: var(--card-bg2);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transform: translateY(-100%);
    transition: transform 0.42s cubic-bezier(0.16,1,0.3,1);
  }
  .search-drawer.is-open { transform: translateY(0); }

  /* ── Input row ── */
  .search-drawer-inner {
    max-width: 800px; margin: 0 auto;
    display: flex; align-items: center; gap: 20px;
    padding: 32px var(--page-padding) 28px;
  }

  /* Form — minimal underline, no boxy container */
  .search-drawer form {
    flex: 1;
    display: flex; align-items: center; gap: 14px;
    background: none; border: none; border-radius: 0;
    padding: 0 0 12px;
    position: relative;
  }
  /* Baseline — thin cream line */
  .search-drawer form::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: rgba(255,249,239,0.10);
  }
  /* Earth accent line — grows from left on focus */
  .search-drawer form::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 0; height: 1px;
    background: var(--earth);
    transition: width 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .search-drawer form:focus-within::after { width: 100%; }

  /* Search icon — dim until focused */
  .search-drawer form svg.search-icon {
    width: 17px; height: 17px;
    color: rgba(255,249,239,0.25);
    flex-shrink: 0;
    transition: color 0.3s;
    stroke-width: 1.5;
  }
  .search-drawer form:focus-within svg.search-icon { color: var(--earth); }

  /* THE FIX — body font, light weight, zero excess tracking */
  .search-drawer input[type="search"] {
    flex: 1;
    background: none; border: none; outline: none;
    color: var(--cream);
    font-family: var(--font);
    font-size: 20px;
    font-weight: 300;
    letter-spacing: 0;
    height: 44px;
    caret-color: var(--earth);
  }
  .search-drawer input[type="search"]::placeholder {
    color: rgba(255,249,239,0.20);
    font-weight: 300;
  }
  .search-drawer input[type="search"]::-webkit-search-cancel-button { display: none; }

  /* Close button */
  .search-close {
    background: none; border: none; cursor: pointer;
    color: rgba(255,249,239,0.25); padding: 6px; flex-shrink: 0;
    display: flex; align-items: center;
    transition: color 0.2s, transform 0.3s cubic-bezier(0.16,1,0.3,1);
  }
  .search-close:hover { color: var(--cream); transform: rotate(90deg); }
  .search-close svg { width: 18px; height: 18px; stroke-width: 1.5; }

  /* ── Predictive results panel ── */
  .search-results-panel {
    max-width: 800px; margin: 0 auto;
    padding: 0 var(--page-padding) 36px;
    display: none;
  }
  .search-results-panel.has-results { display: block; }

  /* Divider */
  .search-results-panel::before {
    content: '';
    display: block;
    height: 1px;
    background: rgba(255,255,255,0.05);
    margin-bottom: 28px;
  }

  /* Product grid */
  .search-pred-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }
  @media (max-width: 900px) { .search-pred-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 560px) { .search-pred-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; } }

  .search-pred-item {
    text-decoration: none; color: inherit;
    display: block;
    border-radius: 10px;
    overflow: hidden;
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.04);
    transition: border-color 0.25s, transform 0.25s cubic-bezier(0.16,1,0.3,1);
    outline-offset: 3px;
  }
  .search-pred-item:hover,
  .search-pred-item:focus {
    border-color: rgba(196,168,122,0.35);
    transform: translateY(-3px);
  }
  .search-pred-item.is-active { border-color: rgba(196,168,122,0.35); }

  .search-pred-img {
    aspect-ratio: 3/4; overflow: hidden;
    background: rgba(255,255,255,0.03);
  }
  .search-pred-img img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.55s cubic-bezier(0.16,1,0.3,1);
  }
  .search-pred-item:hover .search-pred-img img { transform: scale(1.06); }

  .search-pred-body { padding: 11px 13px 13px; }
  .search-pred-name {
    font-family: var(--font-display); font-size: 10px;
    font-weight: 700; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--cream);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    margin-bottom: 3px;
  }
  .search-pred-price {
    font-family: var(--font);
    font-size: 11px; color: var(--earth);
    font-weight: 400; letter-spacing: 0.04em;
  }

  /* Footer */
  .search-pred-footer {
    margin-top: 24px;
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 16px;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .search-pred-count {
    font-family: var(--font);
    font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(255,249,239,0.30);
  }
  .search-pred-all {
    font-family: var(--font-display); font-size: 10px;
    font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--earth); text-decoration: none;
    display: flex; align-items: center; gap: 7px;
    transition: gap 0.25s cubic-bezier(0.16,1,0.3,1), color 0.2s;
  }
  .search-pred-all:hover { gap: 12px; color: var(--cream); }

  /* Empty / loading states */
  .search-pred-empty {
    font-family: var(--font);
    font-size: 13px; font-weight: 300;
    color: rgba(255,249,239,0.30);
    letter-spacing: 0.04em; padding: 4px 0 8px;
  }
  .search-pred-spinner {
    width: 16px; height: 16px; flex-shrink: 0;
    border: 1.5px solid rgba(255,255,255,0.08);
    border-top-color: var(--earth);
    border-radius: 50%;
    animation: searchSpin 0.7s linear infinite;
    display: none;
  }
  .search-drawer form.is-loading .search-pred-spinner { display: block; }
  .search-drawer form.is-loading svg.search-icon { display: none; }
  @keyframes searchSpin { to { transform: rotate(360deg); } }
  @media (max-width: 560px) {
    .search-drawer-inner { padding: 24px var(--page-padding) 20px; }
    .search-drawer input[type="search"] { font-size: 16px; }
  }
{%- endstyle -%}

<!-- Search Overlay -->
<div class="search-overlay" id="search-overlay" aria-hidden="true"></div>

<!-- Search Drawer -->
<div class="search-drawer" id="search-drawer" role="dialog" aria-label="Search" aria-hidden="true">
  <div class="search-drawer-inner">
    <form action="/search" method="get" role="search" id="search-form">
      <input type="hidden" name="type" value="product">
      <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <div class="search-pred-spinner" aria-hidden="true"></div>
      <input
        type="search"
        name="q"
        id="search-input"
        placeholder="What are you looking for?"
        autocomplete="off"
        autocorrect="off"
        spellcheck="false"
        aria-label="Search products"
        aria-autocomplete="list"
        aria-controls="search-pred-results"
      >
    </form>
    <button class="search-close" id="search-close" aria-label="Close search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>
  <!-- Predictive results -->
  <div class="search-results-panel" id="search-pred-panel" role="region" aria-live="polite">
    <div class="search-pred-grid" id="search-pred-results"></div>
    <div class="search-pred-footer" id="search-pred-footer" style="display:none">
      <span class="search-pred-count" id="search-pred-count"></span>
