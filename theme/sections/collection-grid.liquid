<style>
.collection-card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 40px 40px 48px;
  overflow: clip;
  margin-top: var(--gap);
}
.collection-card h2 {
  font-family: var(--font-display);
  font-size: clamp(2.25rem, 4.5vw, 4rem);
  font-weight: 300;
  letter-spacing: -0.01em;
  text-transform: uppercase;
  line-height: 1;
  margin-bottom: 40px;
}
.collection-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 20px;
  align-items: start;
}
.col-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  cursor: pointer;
  perspective: 700px;
  text-decoration: none;
  color: inherit;
}
.col-img {
  width: 100%;
  aspect-ratio: 185 / 375;
  border-radius: var(--radius);
  overflow: hidden;
  background: #221c10;
  position: relative;
  align-self: stretch;
  flex-shrink: 0;
  margin-bottom: -10.5%;
  transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1), border-radius 0.4s ease;
  will-change: transform;
  transform-style: flat;
  /* iOS Safari: will-change breaks overflow:hidden clipping — isolation fixes it */
  isolation: isolate;
  -webkit-mask-image: -webkit-radial-gradient(white, black);
}
.col-item:hover .col-img { border-radius: var(--radius); }
.col-img img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center top;
  transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  will-change: transform;
}
.col-item:hover .col-img img { transform: scale(1.06); }

/* Gloss shine */
.col-shine {
  position: absolute; inset: 0;
  background: radial-gradient(circle at var(--sx,50%) var(--sy,50%), rgba(255,255,255,0.13) 0%, rgba(255,255,255,0.04) 35%, transparent 65%);
  opacity: 0; pointer-events: none; z-index: 4;
  mix-blend-mode: overlay; transition: opacity 0.3s ease;
}
.col-item:hover .col-shine { opacity: 1; }

/* Hover overlay */
.col-hover-overlay {
  position: absolute; bottom: 0; left: 0; right: 0; z-index: 3;
  padding: 28px 16px 18px;
  background: linear-gradient(to top, rgba(40,30,18,0.98) 0%, rgba(60,45,28,0.92) 40%, rgba(94,75,55,0.55) 70%, transparent 100%);
  transform: translateY(100%);
  transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  display: flex; flex-direction: column; gap: 4px;
}
.col-item:hover .col-hover-overlay { transform: translateY(0); }
.col-hover-name {
  font-family: var(--font-display); font-weight: 700;
  font-size: clamp(15px, 1.6vw, 22px); letter-spacing: 0.04em;
  text-transform: uppercase; color: #FFF9EF; line-height: 1.05;
  opacity: 0; transform: translateY(10px);
  transition: opacity 0.35s ease 0.12s, transform 0.35s cubic-bezier(0.16,1,0.3,1) 0.12s;
}
.col-item:hover .col-hover-name { opacity: 1; transform: translateY(0); }
.col-hover-price {
  font-family: var(--font); font-weight: 400; font-size: 11px;
  letter-spacing: 0.14em; color: var(--earth);
  opacity: 0; transform: translateY(8px);
  transition: opacity 0.3s ease 0.19s, transform 0.3s cubic-bezier(0.16,1,0.3,1) 0.19s;
}
.col-item:hover .col-hover-price { opacity: 1; transform: translateY(0); }
.col-hover-cta {
  display: inline-flex; align-items: center; gap: 6px; margin-top: 8px;
  font-family: var(--font-display); font-size: 10px; font-weight: 700;
  letter-spacing: 0.20em; text-transform: uppercase;
  color: rgba(255,255,255,0.9); border-bottom: 1px solid rgba(255,255,255,0.25);
  padding-bottom: 3px;
  opacity: 0; transform: translateY(6px);
  transition: opacity 0.3s ease 0.25s, transform 0.3s cubic-bezier(0.16,1,0.3,1) 0.25s, border-color 0.3s, color 0.3s;
}
.col-item:hover .col-hover-cta { opacity: 1; transform: translateY(0); }
.col-hover-cta:hover { color: var(--earth); border-color: var(--earth); }

/* Info below image */
.col-info {
  display: flex; flex-direction: column; align-items: flex-start;
  gap: 5px; align-self: stretch; position: relative; z-index: 2;
  padding-top: 6px;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}
.col-item:hover .col-info { transform: translateY(-3px); }
.col-num {
  font-family: var(--font-display); font-weight: 700;
  font-size: clamp(22px, 2.5vw, 38px); line-height: 1.1;
  letter-spacing: 0.04em; color: #FFF9EF;
}
.col-name {
  font-family: var(--font-display); font-weight: 600;
  font-size: clamp(11px, 1.1vw, 16px); line-height: 1.3;
  letter-spacing: 0.04em; color: #FFF9EF; text-transform: uppercase;
}
.col-desc {
  font-family: var(--font-display); font-weight: 400;
  font-size: clamp(10px, 0.95vw, 14px); line-height: 1.55;
  letter-spacing: 0.04em; color: #C8B297;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.col-price {
  font-family: var(--font); font-weight: 400;
  font-size: clamp(11px, 1vw, 14px); letter-spacing: 0.04em;
  color: rgba(255,255,255,0.7); margin-top: 2px;
}
.col-cta {
  margin-top: 6px; font-family: var(--font-display); font-weight: 600;
  font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--earth); opacity: 0; transform: translateX(-6px);
  transition: opacity 0.3s ease, transform 0.3s ease, color 0.3s;
}
@media (pointer: fine) { .col-cta { display: none; } }
@media (pointer: coarse) { .col-cta { opacity: 1; transform: none; } }

/* Badge */
.col-badge {
  position: absolute; top: 10px; left: 10px; z-index: 3;
  font-family: var(--font); font-size: 10px; font-weight: 700;
  letter-spacing: 0.20em; text-transform: uppercase;
  padding: 4px 8px; border-radius: 3px; pointer-events: none;
}
.col-badge--best { background: var(--earth); color: #1A1208; }
.col-badge--new { background: rgba(255,255,255,0.92); color: #1A1208; }

/* Responsive */
@media (max-width: 1200px) { .collection-grid { grid-template-columns: repeat(4, 1fr); gap: 16px; } }
@media (max-width: 900px) {
  .collection-card { padding: 32px 24px 40px; }
  .collection-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
  .col-num  { font-size: clamp(22px, 3.5vw, 34px); }
  .col-name { font-size: clamp(11px, 1.6vw, 16px); }
  .col-desc { font-size: clamp(10px, 1.4vw, 14px); }
}
@media (max-width: 560px) {
  .collection-card { padding: 24px 20px 32px; border-radius: 8px; }
  .collection-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .col-img { border-radius: 8px; }
  .col-num  { font-size: clamp(20px, 5.5vw, 30px); }
  .col-name { font-size: clamp(10px, 2.8vw, 14px); }
  .col-desc { font-size: clamp(10px, 2.4vw, 13px); line-height: 1.45; }
}
</style>

<div class="collection-card reveal" id="collections">
  <h2>{{ section.settings.heading | default: 'Collections' }}</h2>
  <div class="collection-grid stagger">
    {%- for block in section.blocks -%}
      {%- assign p = block.settings.product -%}
      {%- assign card_title = block.settings.title_override | default: p.title | default: 'Product' -%}
      {%- assign card_price = p.price | money_without_trailing_zeros | default: block.settings.price_override -%}
      {%- assign card_link = p.url | default: block.settings.link | default: '#' -%}
      {%- assign card_image = block.settings.image | default: p.featured_image -%}
      {%- assign card_desc = block.settings.description | default: p.description | strip_html | truncate: 60 -%}

      <a class="col-item" href="{{ card_link }}" {{ block.shopify_attributes }}>
        <div class="col-img">
          {%- if block.settings.badge != blank -%}
            <span class="col-badge {% if block.settings.badge == 'New' %}col-badge--new{% else %}col-badge--best{% endif %}">{{ block.settings.badge }}</span>
          {%- endif -%}
          <div class="col-shine"></div>
          <div class="col-hover-overlay">
            <div class="col-hover-name">{{ card_title }}</div>
            <div class="col-hover-price">{{ card_price }}{% if block.settings.size_range != blank %} · {{ block.settings.size_range }}{% endif %}</div>
            <span class="col-hover-cta">View Product →</span>
          </div>
          {%- if card_image != blank -%}
            <img
              src="{{ card_image | image_url: width: 600 }}"
              srcset="{{ card_image | image_url: width: 300 }} 300w,
                     {{ card_image | image_url: width: 500 }} 500w,
                     {{ card_image | image_url: width: 800 }} 800w"
              sizes="(max-width: 560px) 45vw, (max-width: 900px) 45vw, 20vw"
              alt="{{ card_title | escape }}"
              loading="eager"
              decoding="async"
            >
          {%- else -%}
            <div style="background:#221c10;position:absolute;inset:0;"></div>
          {%- endif -%}
        </div>
        <div class="col-info">
          <div class="col-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}.</div>
          <div class="col-name">{{ card_title }}</div>
          <div class="col-desc">{{ card_desc }}</div>
          <div class="col-price">{{ card_price }}</div>
          <span class="col-cta">Shop Now →</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

<script>
(function(){
  var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (prefersReduced || !window.matchMedia('(pointer: fine)').matches) return;
  document.querySelectorAll('.col-item').forEach(function(item) {
    var imgEl = item.querySelector('.col-img');
    var shine = item.querySelector('.col-shine');
    if (!imgEl) return;
    var raf = null, TILT = 10;
    item.addEventListener('mouseenter', function() {
      imgEl.style.transition = 'transform 0.08s linear, border-radius 0.4s ease';
    }, { passive: true });
    item.addEventListener('mousemove', function(e) {
      if (raf) cancelAnimationFrame(raf);
      raf = requestAnimationFrame(function() {
        var rect = imgEl.getBoundingClientRect();
        var x = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
        var y = Math.max(0, Math.min(1, (e.clientY - rect.top) / rect.height));
        var tiltX = (0.5 - y) * TILT;
        var tiltY = (x - 0.5) * TILT;
        imgEl.style.transform = 'perspective(700px) rotateX('+tiltX+'deg) rotateY('+tiltY+'deg) scale(1.03)';
        if (shine) {
          shine.style.background = 'radial-gradient(circle at '+x*100+'% '+y*100+'%, rgba(255,255,255,0.16) 0%, rgba(255,255,255,0.05) 35%, transparent 62%)';
        }
      });
    }, { passive: true });
    item.addEventListener('mouseleave', function() {
      if (raf) { cancelAnimationFrame(raf); raf = null; }
      imgEl.style.transition = 'transform 0.7s cubic-bezier(0.16, 1, 0.3, 1), border-radius 0.4s ease';
      imgEl.style.transform = '';
      if (shine) shine.style.background = '';
    }, { passive: true });
  });
})();
</script>

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Collections" }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Featured Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "text", "id": "title_override", "label": "Title override (optional)" },
        { "type": "text", "id": "price_override", "label": "Price override (optional)" },
        { "type": "text", "id": "description", "label": "Description override" },
        { "type": "text", "id": "size_range", "label": "Size range" },
        { "type": "text", "id": "badge", "label": "Badge (e.g. Bestseller, 3-Pack)" },
        { "type": "image_picker", "id": "image", "label": "Image override (optional)" },
        { "type": "url", "id": "link", "label": "Link override (optional)" }
      ]
    }
  ]
}
{% endschema %}
