    <span class="marquee-item">Unisex Essentials</span><span class="marquee-sep">&#10022;</span>
    <span class="marquee-item">Made To Last</span><span class="marquee-sep">&#10022;</span>
    <span class="marquee-item">Free Returns</span><span class="marquee-sep">&#10022;</span>
    <span class="marquee-item">Comfort As Practice</span><span class="marquee-sep">&#10022;</span>
    <span class="marquee-item">All Is Well.</span><span class="marquee-sep">&#10022;</span>
    <span class="marquee-item">Unisex Essentials</span><span class="marquee-sep">&#10022;</span>
    <span class="marquee-item">Made To Last</span><span class="marquee-sep">&#10022;</span>
    <span class="marquee-item">Free Returns</span><span class="marquee-sep">&#10022;</span>
    <span class="marquee-item">Comfort As Practice</span><span class="marquee-sep">&#10022;</span>
  </div>
</div>

