{%- style -%}
/* ── Section card wrapper ── */
.stub-section {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: var(--card-padding);
  margin-top: var(--gap);
}
{%- endstyle -%}

<section class="stub-section" id="shopify-section-{{ section.id }}">
  <h2>{{ section.settings.heading }}</h2>
</section>

{% schema %}
{
  "name": "Section Name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Section Heading"
    }
  ],
  "presets": [
    {
      "name": "Section Name"
    }
  ]
}
{% endschema %}
