<style>
.plan-card {
  background: var(--card-bg);
  border-radius: var(--radius);
  overflow: hidden;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  align-items: stretch;
  margin-top: var(--gap);
  min-height: 480px;
}
.plan-left {
  padding: 48px 48px 56px;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}
.plan-left h2 {
  font-family: var(--font-display);
  font-size: clamp(2.25rem, 4.5vw, 3.75rem);
  font-weight: 300;
  letter-spacing: -0.01em;
  text-transform: uppercase;
  line-height: 1;
  margin-bottom: 6px;
}
.plan-sub {
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--earth); margin-bottom: 32px;
}
.plan-rows { display: flex; flex-direction: column; }
.plan-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 13px 0;
  border-bottom: 1px solid var(--border);
  transition: background 0.3s, padding-left 0.3s;
  text-decoration: none; color: inherit;
}
.plan-row:first-child { border-top: 1px solid var(--border); }
.plan-row:hover { background: rgba(255,255,255,0.03); padding-left: 12px; }
.plan-item {
  font-size: 13px; font-weight: 300; letter-spacing: 0.04em;
  color: rgba(255,255,255,0.85); transition: color 0.3s;
}
.plan-row:hover .plan-item { color: var(--white); }
.plan-detail {
  font-size: 11px; font-weight: 600; letter-spacing: 0.08em; color: var(--muted);
}

/* ── Right column: single feature image ── */
.plan-feature {
  position: relative;
  overflow: hidden;
  min-height: 480px;
}
.plan-feature img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 65%;
  display: block;
}
/* Left-edge blend into card + subtle bottom vignette */
.plan-feature::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to right, rgba(58,48,32,0.72) 0%, rgba(58,48,32,0.18) 28%, transparent 52%),
    linear-gradient(to top, rgba(26,18,8,0.45) 0%, transparent 35%);
  pointer-events: none;
}

@media (max-width: 900px) {
  .plan-card {
    grid-template-columns: 1fr;
    min-height: unset;
  }
  .plan-left { padding: 36px 28px 40px; }
  .plan-feature {
    min-height: 360px;
    order: -1; /* image on top on tablet */
  }
}
@media (max-width: 560px) {
  .plan-card { border-radius: 10px; }
  .plan-left { padding: 28px 20px 32px; }
  .plan-feature { min-height: 300px; }
}
</style>

<div class="plan-card">
  <div class="plan-left slide-left">
    <h2>{{ section.settings.heading | default: 'The Essentials' }}</h2>
    <div class="plan-sub">{{ section.settings.subheading | default: 'Full Collection — SS 2025' }}</div>
    <div class="plan-rows stagger">
      {%- for block in section.blocks -%}
        {%- if block.type == 'product_row' -%}
          <a href="{{ block.settings.link | default: '#' }}" class="plan-row" {{ block.shopify_attributes }}>
            <span class="plan-item">{{ block.settings.name }}</span>
            <span class="plan-detail">{{ block.settings.detail }}</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="plan-feature reveal">
    {%- if section.settings.feature_image != blank -%}
      <img
        src="{{ section.settings.feature_image | image_url: width: 900 }}"
        srcset="{{ section.settings.feature_image | image_url: width: 600 }} 600w,
               {{ section.settings.feature_image | image_url: width: 900 }} 900w,
               {{ section.settings.feature_image | image_url: width: 1200 }} 1200w"
        sizes="(max-width: 900px) 100vw, 50vw"
        alt="{{ section.settings.feature_image.alt | default: 'All Is Well Essentials' }}"
        loading="lazy"
        decoding="async"
      >
    {%- else -%}
      <img
        src="{{ 'essentials-feature.jpg' | asset_url }}"
        alt="All Is Well Essentials"
        loading="lazy"
        decoding="async"
      >
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Essentials Table",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Essentials" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Full Collection — SS 2025" },
    { "type": "image_picker", "id": "feature_image", "label": "Feature image (right column)" }
  ],
  "blocks": [
    {
      "type": "product_row",
      "name": "Product Row",
      "settings": [
        { "type": "text", "id": "name", "label": "Product name", "default": "Essential Tee" },
        { "type": "text", "id": "detail", "label": "Details", "default": "XS – 3XL · 4 Colours · $48" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ]
}
{% endschema %}
