{%- style -%}
  .search-page {
    padding: var(--page-padding);
    max-width: 1200px;
    margin: 0 auto;
  }
  .search-page-header {
    padding: 48px 0 40px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    margin-bottom: 40px;
  }
  .search-page-label {
    font-size: 10px; font-weight: 600; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--muted);
    margin-bottom: 12px;
  }
  .search-page-form {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--card-bg);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 0 20px;
    max-width: 560px;
    transition: border-color 0.2s;
  }
  .search-page-form:focus-within {
    border-color: rgba(255,255,255,0.2);
  }
  .search-page-form svg {
    width: 16px; height: 16px; color: var(--muted); flex-shrink: 0;
  }
  .search-page-form input[type="search"] {
    flex: 1; background: none; border: none; outline: none;
    color: var(--white); font-size: 16px; height: 52px;
    font-family: inherit; letter-spacing: 0.04em;
  }
  .search-page-form input[type="search"]::placeholder { color: var(--muted); }
  .search-page-form input[type="search"]::-webkit-search-cancel-button { display: none; }
  .search-results-count {
    font-size: 13px; color: var(--muted); margin-bottom: 32px;
    letter-spacing: 0.08em;
  }
  .search-results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 24px;
  }
  .search-result-card {
    background: var(--card-bg);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.2s var(--ease-out-expo), box-shadow 0.2s;
  }
  .search-result-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .search-result-img {
    aspect-ratio: 3/4; overflow: hidden; background: rgba(255,255,255,0.03);
  }
  .search-result-img img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.5s var(--ease-out-expo);
  }
  .search-result-card:hover .search-result-img img { transform: scale(1.04); }
  .search-result-body { padding: 16px 20px 20px; }
  .search-result-title {
    font-size: 13px; font-weight: 600; letter-spacing: 0.04em;
    text-transform: uppercase; color: var(--white);
    margin-bottom: 6px;
  }
  .search-result-price {
    font-size: 13px; color: var(--muted); font-weight: 400;
  }
  .search-no-results {
    text-align: center; padding: 80px 0;
    color: var(--muted); font-size: 14px; letter-spacing: 0.04em;
  }
  .search-no-results strong {
    display: block; font-size: 20px; font-weight: 600;
    color: var(--white); margin-bottom: 12px;
  }
  .search-pagination {
    display: flex; align-items: center; justify-content: center;
    gap: 20px; margin-top: 48px; padding-bottom: 48px;
  }
  .search-page-btn {
    font-family: var(--font-display); font-size: 10px; font-weight: 700;
    letter-spacing: 0.20em; text-transform: uppercase; color: var(--white);
    padding: 10px 20px; border: 1px solid rgba(255,255,255,0.18);
    border-radius: 3px; transition: border-color 0.2s, color 0.2s;
    text-decoration: none;
  }
  .search-page-btn:hover { border-color: var(--earth); color: var(--earth); }
  .search-page-info {
    font-size: 11px; letter-spacing: 0.08em; color: var(--muted);
  }
{%- endstyle -%}

<section class="search-page">
  <div class="search-page-header">
    <p class="search-page-label">Search</p>
    <form action="/search" method="get" class="search-page-form" role="search">
      <input type="hidden" name="type" value="product">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="Search products…"
        autocomplete="off"
        aria-label="Search products"
      >
    </form>
  </div>

  {%- if search.performed -%}
    {%- paginate search.results by 24 -%}
    {%- if search.results_count > 0 -%}
      <p class="search-results-count">
        {{ search.results_count }} {{ search.results_count | pluralize: 'result', 'results' }} for
        <strong>"{{ search.terms | escape }}"</strong>
      </p>
      <div class="search-results-grid">
        {%- for result in search.results -%}
          <a href="{{ result.url }}" class="search-result-card">
            <div class="search-result-img">
              {%- if result.featured_image -%}
                <img
                  src="{{ result.featured_image | image_url: width: 480 }}"
                  alt="{{ result.featured_image.alt | escape }}"
                  loading="lazy" decoding="async" width="480" height="640"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="search-result-body">
              <p class="search-result-title">{{ result.title }}</p>
              {%- if result.object_type == 'product' -%}
                <p class="search-result-price">{{ result.price | money }}</p>
              {%- endif -%}
            </div>
          </a>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="search-pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="search-page-btn">← Prev</a>
          {%- endif -%}
          <span class="search-page-info">{{ paginate.current_page }} / {{ paginate.pages }}</span>
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="search-page-btn">Next →</a>
          {%- endif -%}
        </div>
      {%- endif -%}

    {%- else -%}
      <div class="search-no-results">
        <strong>No results found</strong>
        Try a different search term or browse our
        <a href="/collections/all" style="color: var(--white); text-decoration: underline;">full collection</a>.
      </div>
    {%- endif -%}
    {%- endpaginate -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Search results",
  "settings": []
}
{% endschema %}
