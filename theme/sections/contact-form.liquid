{%- style -%}
  .contact-section {
    padding: var(--section-gap) 0;
  }

  .contact-card {
    background: var(--card-bg);
    border-radius: var(--radius);
    padding: var(--card-padding-b) var(--card-padding);
    max-width: 720px;
    margin: 0 auto;
    width: 100%;
  }

  .contact-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--cream);
    margin-bottom: var(--space-3);
    line-height: 1.1;
  }

  .contact-intro {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  .form-group {
    margin-bottom: var(--space-5);
  }

  .form-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: var(--space-2);
    display: block;
  }

  .form-input,
  .form-textarea {
    width: 100%;
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-sm);
    background: var(--card-bg2);
    border: 1px solid var(--border);
    color: var(--cream);
    font-family: var(--font);
    font-size: 13px;
    font-weight: 400;
    outline: none;
    transition: border-color var(--duration-fast);
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--dim);
  }

  .form-input:focus,
  .form-textarea:focus {
    border-color: var(--earth);
  }

  .form-textarea {
    min-height: 160px;
    resize: vertical;
  }

  .form-submit {
    margin-top: var(--space-9);
    width: 100%;
    padding: var(--space-5) var(--space-7);
    background: var(--earth);
    color: var(--earth-dark, #2E2618);
    border: none;
    border-radius: var(--radius-sm);
    font-family: var(--font);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .form-submit:hover {
    opacity: 0.85;
  }

  @media (max-width: 560px) {
    .contact-card {
      padding: var(--space-8) var(--space-5);
    }
  }
{%- endstyle -%}

<section class="contact-section">
  <div class="contact-card reveal">
    <h1 class="contact-title">{{ section.settings.heading | default: "Get In Touch" }}</h1>
    <p class="contact-intro">{{ section.settings.intro | default: "We'd love to hear from you. Send us a message and we'll get back to you within 24 hours." }}</p>

    {%- form 'contact' -%}
      {%- if form.posted_successfully? -%}
        <p style="color:var(--earth);margin-bottom:var(--space-6);font-size:13px;">Thanks for reaching out. We'll be in touch soon.</p>
      {%- endif -%}

      <div class="form-group">
        <label class="form-label" for="contact-name">Name</label>
        <input class="form-input" type="text" id="contact-name" name="contact[name]" placeholder="Your name" required autocomplete="name">
      </div>

      <div class="form-group">
        <label class="form-label" for="contact-email">Email</label>
        <input class="form-input" type="email" id="contact-email" name="contact[email]" placeholder="your@email.com" required autocomplete="email">
      </div>

      <div class="form-group">
        <label class="form-label" for="contact-message">Message</label>
        <textarea class="form-textarea" id="contact-message" name="contact[body]" placeholder="What's on your mind?" required></textarea>
      </div>

      <button type="submit" class="form-submit">Send Message</button>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get In Touch"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro text",
      "default": "We'd love to hear from you. Send us a message and we'll get back to you within 24 hours."
    }
  ]
}
{% endschema %}
