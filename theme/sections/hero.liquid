<style>
.hero-card {
  position: relative;
  height: 78vh;
  min-height: 520px;
  max-height: 860px;
  overflow: hidden;
  border-radius: var(--radius);
  background: var(--card-bg2);
  margin-top: var(--gap);
}
.hero-bg {
  position: absolute;
  inset: -20px;
  will-change: transform;
  transform: translate3d(0, 0, 0);
}
.hero-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  transform: translateZ(0);
  backface-visibility: hidden;
}
.hero-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to bottom, rgba(10,6,2,0.30) 0%, transparent 28%),
    linear-gradient(to top, rgba(26,18,8,0.96) 0%, rgba(20,13,4,0.72) 30%, rgba(10,6,2,0.25) 55%, transparent 75%);
}
.hero-brand {
  position: absolute;
  bottom: 32px; left: 32px;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.hero-brand h1 {
  font-family: var(--font-display);
  font-size: clamp(3.25rem, 8.5vw, 8.125rem);
  font-weight: 900;
  letter-spacing: -0.02em;
  white-space: nowrap;
  line-height: 0.88;
  text-transform: uppercase;
  color: var(--white);
  opacity: 0;
  transform: translateY(30px);
  animation: heroReveal 1s cubic-bezier(0.16, 1, 0.3, 1) 2.4s forwards;
}
.hero-tagline {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.65);
  opacity: 0;
  animation: heroReveal 0.8s ease 2.8s forwards;
}
.hero-location {
  position: absolute;
  bottom: 32px; right: 32px;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--dim);
  z-index: 10;
  opacity: 0;
  animation: heroReveal 0.6s ease 3.0s forwards;
}
.hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin-top: 20px;
  padding: 14px 28px;
  background: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.30);
  border-radius: 2px;
  font-family: var(--font-display);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.20em;
  text-transform: uppercase;
  color: var(--white);
  cursor: pointer;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  opacity: 0;
  animation: heroReveal 0.8s ease 3.1s forwards;
  transition: background 0.3s, border-color 0.3s, transform 0.3s;
}
.hero-cta:hover {
  background: rgba(255,255,255,0.18);
  border-color: rgba(255,255,255,0.55);
  transform: translateY(-2px);
}
.hero-cta-arrow {
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
.hero-cta:hover .hero-cta-arrow { transform: translateX(4px); }
@keyframes heroReveal { to { opacity: 1; transform: translateY(0); } }

@media (max-width: 900px) {
  .hero-card { height: 82vh; min-height: 520px; }
  .hero-brand { bottom: 24px; left: 24px; }
}
@media (max-width: 560px) {
  .hero-card {
    height: 65vh;
    min-height: 400px;
    max-height: unset;
    position: relative;
    overflow: hidden;
    background: var(--card-bg2);
    border-radius: var(--radius);
  }
  /* Force bg to fill card completely */
  .hero-bg {
    position: absolute !important;
    inset: 0 !important;
    width: 100%;
    height: 100%;
    transform: none;
    will-change: auto;
  }
  /* Force image to fill bg completely */
  .hero-bg img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  /* Text sits inside the image at the bottom */
  .hero-brand {
    position: absolute;
    bottom: 24px; left: 24px; right: 24px;
    gap: 8px;
  }
  .hero-brand h1 { font-size: clamp(2rem, 11vw, 3rem); white-space: normal; line-height: 0.92; }
  .hero-tagline { font-size: 10px; }
  .hero-location { display: none; }
  .hero-cta { padding: 12px 22px; font-size: 10px; margin-top: 12px; }
}
</style>

<div class="hero-card scale-up">
  <div class="hero-bg" id="heroBg">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1600 }}"
        srcset="{{ section.settings.image | image_url: width: 800 }} 800w,
               {{ section.settings.image | image_url: width: 1200 }} 1200w,
               {{ section.settings.image | image_url: width: 1600 }} 1600w,
               {{ section.settings.image | image_url: width: 2000 }} 2000w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: shop.name }}"
        loading="eager"
        decoding="async"
      >
    {%- elsif section.settings.video != blank -%}
      <video autoplay muted loop playsinline>
        <source src="{{ section.settings.video }}" type="video/mp4">
      </video>
    {%- endif -%}
  </div>

  <div class="hero-brand">
    {%- if section.settings.heading != blank -%}
      <h1>{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <div class="hero-tagline">{{ section.settings.subheading }}</div>
    {%- endif -%}
    {%- if section.settings.cta_text != blank -%}
      <a href="{{ section.settings.cta_link | default: '#collections' }}" class="hero-cta">
        {{ section.settings.cta_text }} <span class="hero-cta-arrow" aria-hidden="true">→</span>
      </a>
    {%- endif -%}
  </div>
  <div class="hero-location">{{ section.settings.location | default: 'Dallas, TX — Est. 2025' }}</div>
</div>

<script>
(function(){
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const heroBg = document.getElementById('heroBg');
  const heroCard = heroBg ? heroBg.closest('.hero-card') : null;
  let heroVisible = true;
  let rafPending = false;

  const isTouch = window.matchMedia('(pointer: coarse)').matches;
  const parallaxRate = isTouch ? 0.08 : 0.22;
  if (heroBg && !prefersReduced) {
    const heroObserver = new IntersectionObserver(([entry]) => {
      heroVisible = entry.isIntersecting;
    }, { threshold: 0 });
    if (heroCard) heroObserver.observe(heroCard);

    window.addEventListener('scroll', () => {
      if (!heroVisible || rafPending) return;
      rafPending = true;
      requestAnimationFrame(() => {
        heroBg.style.transform = 'translate3d(0,' + (window.scrollY * parallaxRate) + 'px, 0)';
        rafPending = false;
      });
    }, { passive: true });
  }
})();
</script>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "All Is Well." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Wear it like you mean it." },
    { "type": "text", "id": "location", "label": "Location text", "default": "Dallas, TX — Est. 2025" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Shop the Collection" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "url", "id": "video", "label": "Hero video URL (mp4)" }
  ]
}
{% endschema %}
