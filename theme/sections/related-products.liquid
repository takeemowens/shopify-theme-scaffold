{%- if recommendations.products.size > 0 -%}
<div class="related-card reveal">
  <div class="related-header">
    <h2 class="heading-lg">{{ section.settings.heading | default: 'You May Also Like' }}</h2>
    <a href="/collections/all" class="eyebrow" style="border-bottom:1px solid var(--earth);padding-bottom:2px;">View All</a>
  </div>
  <div class="related-grid stagger">
    {%- for product in recommendations.products limit: 4 -%}
      <a href="{{ product.url }}" class="product-card-mini">
        <div class="product-card-mini__img">
          {%- if product.featured_image != blank -%}
            <img
              src="{{ product.featured_image | image_url: width: 500 }}"
              alt="{{ product.featured_image.alt | default: product.title }}"
              loading="lazy"
              decoding="async"
            >
          {%- else -%}
            <div style="background:var(--ph{{ forloop.index }});width:100%;height:100%;"></div>
          {%- endif -%}
        </div>
        <div class="product-card-mini__name">{{ product.title }}</div>
        <div class="product-card-mini__sub">{{ product.type }}</div>
        <div class="product-card-mini__price">{{ product.price | money_without_trailing_zeros }}</div>
      </a>
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Related Products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    }
  ],
  "presets": [
    {
      "name": "Related Products"
    }
  ]
}
{% endschema %}
