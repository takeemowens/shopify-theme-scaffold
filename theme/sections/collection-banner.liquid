{%- style -%}
  .collection-banner {
    background: var(--card-bg);
    border-radius: var(--radius);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: var(--space-9) var(--space-11);
    margin-top: var(--gap);
  }

  /* If collection has an image, show it as bg */
  .collection-banner--has-image {
    min-height: 280px;
  }
  .collection-banner__bg {
    position: absolute;
    inset: 0;
  }
  .collection-banner__bg img {
    width: 100%; height: 100%; object-fit: cover;
    display: block;
    transition: transform 6s var(--ease-out-expo);
  }
  .collection-banner:hover .collection-banner__bg img {
    transform: scale(1.03);
  }
  .collection-banner__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top,
        rgba(var(--overlay-dark), 0.92) 0%,
        rgba(var(--overlay-dark), 0.5) 50%,
        rgba(var(--overlay-dark), 0.15) 80%,
        transparent 100%);
  }
  .collection-banner__bg::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.03;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .collection-banner__content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: baseline;
    gap: var(--space-5);
  }
  .collection-banner__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    text-transform: uppercase;
    color: var(--cream);
    line-height: 1.2;
    margin: 0;
  }
  .collection-banner__count {
    font-family: var(--font);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--earth);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    white-space: nowrap;
  }
  .collection-banner__desc {
    position: relative;
    z-index: 2;
    font-family: var(--font);
    font-size: var(--text-base);
    color: var(--muted);
    letter-spacing: 0.02em;
    max-width: 320px;
    line-height: 1.5;
    text-align: right;
  }

  @media (max-width: 900px) {
    .collection-banner {
      padding: var(--space-7) var(--space-8);
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }
    .collection-banner--has-image { min-height: 220px; }
    .collection-banner__desc { text-align: left; max-width: 100%; }
  }
  @media (max-width: 560px) {
    .collection-banner {
      padding: var(--space-6) var(--space-5);
    }
    .collection-banner--has-image { min-height: 180px; }
    .collection-banner__content { gap: var(--space-3); }
    .collection-banner__title { font-size: clamp(1.25rem, 5vw, 1.75rem); }
  }
{%- endstyle -%}

<div class="collection-banner{% if collection.image != blank %} collection-banner--has-image{% endif %} reveal">
  {%- if collection.image != blank -%}
    <div class="collection-banner__bg">
      <img
        src="{{ collection.image | image_url: width: 1200 }}"
        srcset="{{ collection.image | image_url: width: 600 }} 600w,
               {{ collection.image | image_url: width: 900 }} 900w,
               {{ collection.image | image_url: width: 1200 }} 1200w,
               {{ collection.image | image_url: width: 1600 }} 1600w"
        sizes="100vw"
        alt="{{ collection.title | escape }}"
        loading="eager"
        decoding="async"
      >
    </div>
  {%- endif -%}
  <div class="collection-banner__content">
    <h1 class="collection-banner__title">{{ collection.title }}</h1>
    <span class="collection-banner__count">{{ collection.products_count }} {{ collection.products_count | pluralize: 'Piece', 'Pieces' }}</span>
  </div>
  {%- if collection.description != blank -%}
    <p class="collection-banner__desc">{{ collection.description | strip_html | truncate: 100 }}</p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Collection Banner",
  "settings": []
}
{% endschema %}
